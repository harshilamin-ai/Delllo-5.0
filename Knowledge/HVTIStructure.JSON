{
  "schema_version": "1.0",
  "object_name": "HVTIStructure.JSON",
  "description": "Default HVTI parameter structure used by RAIN5.0 to estimate match quality from CILProfiles.",
  "score_model": {
    "score_min": 0,
    "score_max": 100,
    "score_formula": "weighted_average(HVTI parameter scores)",
    "probability_formula": "min_probability + (HVTIScore / 100) * (max_probability - min_probability)"
  },
  "probability_model": {
    "description": "Convert weighted HVTI factor score into transaction probability using configured min/max probability bounds.",
    "min_probability": 0.05,
    "max_probability": 0.65
  },
  "value_model": {
    "currency": "USD",
    "default_gbp_to_usd": 1.27,
    "default_value_discount_factor": 1.0,
    "roi_formula": "estimated_potential_value_usd * estimated_probability_of_transaction",
    "explanation": "EstimatedHVITUSDValue is potential value of the meeting in USD before conversion probability. Expected value can be derived by multiplying by the estimated transaction probability."
  },
  "parameters": [
